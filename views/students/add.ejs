<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
    <%- include('../partials/head') %>
    <title>VILNIUS TECH | <%= t('students.addNewStudent') %></title>
</head>
<body>
    <div class="dash">
        <%- include('../partials/sidebar') %>
        
        <main class="main">
            <%- include('../partials/header') %>

            <div class="content">
                <div class="card">
                    <div class="card-head">
                        <h2><%= t('students.addNewStudent') %></h2>
                        <a href="/admin/students" class="btn ghost"><%= t('students.back') %></a>
                    </div>
                    
                    <% if(error_msg && error_msg.length > 0){ %>
                        <div class="alert alert-danger"><%= error_msg %></div>
                    <% } %>

                    <form action="/admin/students" method="POST" class="profile-change-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="text" name="student_id" required class="profile-change-input" placeholder="<%= t('students.studentId') %>">
                        <input type="text" name="full_name" required class="profile-change-input" placeholder="<%= t('students.fullName') %>">
                        <input type="email" name="email" required class="profile-change-input" placeholder="<%= t('students.email') %>">
                        <input type="text" name="program_department" required class="profile-change-input" placeholder="<%= t('students.programDepartment') %>">
                        <input type="number" name="year_of_study" min="1" max="12" required class="profile-change-input" placeholder="<%= t('students.yearOfStudy') %>">
                        <select name="status" required class="profile-change-input">
                            <option value="Active"><%= t('students.active') %></option>
                            <option value="Inactive"><%= t('students.inactive') %></option>
                        </select>
                        <button type="submit" class="btn profile-change-submit"><%= t('students.addStudent') %></button>
                    </form>
                </div>
            </div>

            <%- include('../partials/footer') %>
        </main>
    </div>
</body>
</html>
