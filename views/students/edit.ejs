<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
    <%- include('../partials/head') %>
    <title>VILNIUS TECH | <%= t('students.editStudent') %></title>
</head>
<body>
    <div class="dash">
        <%- include('../partials/sidebar') %>
        
        <main class="main">
            <%- include('../partials/header') %>

            <div class="content">
                <div class="card">
                    <div class="card-head">
                        <h2><%= t('students.editStudent') %></h2>
                        <a href="/admin/students" class="btn ghost"><%= t('students.back') %></a>
                    </div>

                    <% if(error_msg && error_msg.length > 0){ %>
                        <div class="alert alert-danger"><%= error_msg %></div>
                    <% } %>

                    <form action="/admin/students/<%= student.id %>" method="POST" class="profile-change-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="text" name="student_id" value="<%= student.student_id %>" required class="profile-change-input" placeholder="<%= t('students.studentId') %>">
                        <input type="text" name="full_name" value="<%= student.display_full_name %>" required class="profile-change-input" placeholder="<%= t('students.fullName') %>">
                        <input type="email" name="email" value="<%= student.email %>" required class="profile-change-input" placeholder="<%= t('students.email') %>">
                        <input type="text" name="username" value="<%= student.username || '' %>" class="profile-change-input" placeholder="<%= t('students.linkedUsername') %> (<%= t('students.noLinkedUser') %>)">
                        <input type="text" name="program_department" value="<%= student.program_department || '' %>" required class="profile-change-input" placeholder="<%= t('students.programDepartment') %>">
                        <input type="number" name="year_of_study" min="1" max="12" value="<%= student.year_of_study || '' %>" required class="profile-change-input" placeholder="<%= t('students.yearOfStudy') %>">
                        <select name="status" required class="profile-change-input">
                            <option value="Active" <%= student.display_status === 'Active' ? 'selected' : '' %>><%= t('students.active') %></option>
                            <option value="Inactive" <%= student.display_status === 'Inactive' ? 'selected' : '' %>><%= t('students.inactive') %></option>
                        </select>

                        <div>
                          <button type="button" id="togglePasswordFields" class="btn ghost"><%= t('students.advancedPassword') %></button>
                        </div>
                        <div id="passwordFields" class="schedule-day-block" hidden>
                            <p class="muted" style="margin-bottom:10px; font-size:13px;"><%= t('students.hiddenAction') %></p>
                            <input type="password" name="new_password" class="profile-change-input" placeholder="<%= t('students.newPassword') %>">
                            <input type="password" name="confirm_password" class="profile-change-input" placeholder="<%= t('students.confirmNewPassword') %>">
                        </div>

                        <button type="submit" class="btn profile-change-submit"><%= t('students.updateStudent') %></button>
                    </form>
                </div>
            </div>

            <%- include('../partials/footer') %>
        </main>
    </div>
    <script>
      const toggleBtn = document.getElementById('togglePasswordFields');
      const panel = document.getElementById('passwordFields');
      if (toggleBtn && panel) {
        toggleBtn.addEventListener('click', () => {
          const isHidden = panel.hasAttribute('hidden');
          if (isHidden) {
            panel.removeAttribute('hidden');
            toggleBtn.textContent = '<%= t('students.hidePasswordFields') %>';
          } else {
            panel.setAttribute('hidden', '');
            toggleBtn.textContent = '<%= t('students.advancedPassword') %>';
          }
        });
      }
    </script>
</body>
</html>
