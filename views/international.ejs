<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
  <%- include('partials/head') %>
  <% const page = t('internationalPage'); %>
  <title>VILNIUS TECH | <%= page.title %></title>
</head>
<body>
  <div class="dash">
    <%- include('partials/sidebar') %>
    <main class="main">
      <%- include('partials/header') %>
      <section class="content">
        <article class="card">
          <div class="card-head">
            <h2><%= page.title %></h2>
            <span class="badge"><%= page.badge %></span>
          </div>
          <div class="stats" style="margin-bottom:24px;">
            <% page.stats.forEach((stat) => { %>
              <div class="stat"><strong><%= stat.value %></strong><small><%= stat.label %></small></div>
            <% }) %>
          </div>
          <div style="display:grid;gap:14px;">
            <div class="list-item" style="padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <i class="fa-brands fa-earlybirds" style="font-size:20px;color:#67e8f9;"></i>
                <strong><%= page.studyExchange.title %></strong>
                <span class="badge" style="background:rgba(245,158,11,.15);color:#fcd34d;border-color:rgba(245,158,11,.3);margin-left:auto;"><%= page.studyExchange.deadline %></span>
              </div>
              <p style="font-size:13px;color:rgba(255,255,255,.8);line-height:1.6;margin-bottom:8px;"><%= page.studyExchange.description %></p>
              <div class="table-wrap">
                <table class="table">
                  <thead><tr><th><%= page.studyExchange.table.countryCategory %></th><th><%= page.studyExchange.table.monthlyGrant %></th><th><%= page.studyExchange.table.popularDestinations %></th></tr></thead>
                  <tbody>
                    <% page.studyExchange.table.rows.forEach((row) => { %>
                      <tr><td><%= row.category %></td><td><%= row.grant %></td><td><%= row.destinations %></td></tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="list-item" style="padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;"><i class="fa-solid fa-briefcase" style="color:#6ee7b7;font-size:16px;"></i><strong><%= page.traineeship.title %></strong></div>
              <p style="font-size:13px;color:rgba(255,255,255,.8);line-height:1.6;"><%= page.traineeship.description %></p>
            </div>
            <div class="list-item" style="padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;"><i class="fa-solid fa-handshake" style="color:#a5b4fc;font-size:16px;"></i><strong><%= page.bilateral.title %></strong></div>
              <p style="font-size:13px;color:rgba(255,255,255,.8);line-height:1.6;"><%= page.bilateral.description %></p>
            </div>
          </div>
          <div style="margin-top:16px;" class="list-item">
            <p style="padding:14px 16px;font-size:13px;color:rgba(255,255,255,.8);"><%= page.contactPrefix %> <strong>international@vilniustech.lt</strong> | <%= page.contactLocation %> | <%= page.contactHours %></p>
          </div>
        </article>
      </section>
      <%- include('partials/footer') %>
    </main>
  </div>
</body>
</html>
