<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
  <%- include('partials/head') %>
  <% const page = t('safetyPage'); %>
  <title>VILNIUS TECH | <%= page.title %></title>
</head>
<body>
  <div class="dash">
    <%- include('partials/sidebar') %>
    <main class="main">
      <%- include('partials/header') %>
      <section class="content">
        <article class="card" style="margin-bottom:14px;">
          <div class="card-head">
            <h2><%= page.title %></h2>
            <span class="badge"><%= page.badge %></span>
          </div>
          <p class="muted" style="margin-bottom:20px;"><%= page.description %></p>
          <div class="stats" style="margin-bottom:20px;">
            <% page.stats.forEach((stat) => { %>
              <div class="stat"><strong><%= stat.value %></strong><small><%= stat.label %></small></div>
            <% }) %>
          </div>
          <div style="display:grid;gap:12px;">
            <% page.cards.forEach((card) => { %>
              <div class="list-item" style="padding:16px;">
                <strong><i class="<%= card.icon %>" style="margin-right:8px;color:<%= card.color %>;"></i><%= card.title %></strong>
                <p class="muted" style="font-size:12px;margin-top:6px;"><%= card.description %></p>
              </div>
            <% }) %>
          </div>
        </article>

        <article class="card">
          <div class="card-head">
            <h2><%= page.incidentTitle %></h2>
            <span class="badge"><%= page.incidentBadge %></span>
          </div>
          <div class="table-wrap">
            <table class="table">
              <thead><tr><th><%= page.incidentTable.issueType %></th><th><%= page.incidentTable.reportTo %></th><th><%= page.incidentTable.expectedAction %></th></tr></thead>
              <tbody>
                <% page.incidentTable.rows.forEach((row) => { %>
                  <tr><td><%= row.issue %></td><td><%= row.reportTo %></td><td><%= row.action %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </article>
      </section>
      <%- include('partials/footer') %>
    </main>
  </div>
</body>
</html>