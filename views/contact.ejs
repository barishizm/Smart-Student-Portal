<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
  <%- include('partials/head') %>
  <title>VILNIUS TECH | <%= t('footer.contact') %></title>
</head>
<body>
  <div class="dash">
    <%- include('partials/sidebar') %>

    <main class="main">
      <%- include('partials/header') %>

      <section class="content">
        <article class="card">
          <div class="card-head">
            <h2><%= t('contact.title') %></h2>
            <span class="badge"><%= t('contact.form') %></span>
          </div>

          <form
            id="contactForm"
            class="profile-change-form"
            novalidate
            data-required-msg="<%= t('contact.required') %>"
            data-success-msg="<%= t('contact.sent') %>"
            data-invalid-email-msg="<%= t('contact.invalidEmail') %>"
            data-failed-msg="<%= t('contact.failed') %>">
            <div class="form-group">
              <label class="profile-change-title" for="name"><%= t('contact.fullName') %></label>
              <input type="text" id="name" required class="profile-change-input">
            </div>

            <div class="form-group">
              <label class="profile-change-title" for="email"><%= t('contact.emailAddress') %></label>
              <input type="email" id="email" required class="profile-change-input">
            </div>

            <div class="form-group">
              <label class="profile-change-title" for="message"><%= t('contact.message') %></label>
              <textarea id="message" rows="5" required class="profile-change-input"></textarea>
            </div>

            <button type="submit" class="btn profile-change-submit"><%= t('contact.sendMessage') %></button>
          </form>
        </article>
      </section>

      <%- include('partials/footer') %>
    </main>
  </div>

  <script src="/js/contact.js"></script>
</body>
</html>
