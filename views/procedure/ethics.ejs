<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
  <%- include('../partials/head') %>
  <% const page = t('ethicsPage'); %>
  <title>VILNIUS TECH | <%= page.title %></title>
</head>
<body>
  <div class="dash">
    <%- include('../partials/sidebar') %>
    <main class="main">
      <%- include('../partials/header') %>
      <section class="content">
        <article class="card">
          <div class="card-head">
            <h2><%= page.title %></h2>
            <span class="badge"><%= page.badge %></span>
          </div>
          <p class="muted" style="margin-bottom:20px;"><%= page.description %></p>
          <div style="display:grid;gap:14px;">
            <div class="list-item" style="padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <i class="fa-solid fa-scale-balanced" style="color:#67e8f9;font-size:16px;"></i>
                <strong><%= page.principlesTitle %></strong>
              </div>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:6px;padding-left:4px;">
                <% page.principles.forEach((item) => { %>
                  <li style="font-size:13px;color:rgba(255,255,255,.8);"><i class="fa-solid fa-check" style="color:#6ee7b7;margin-right:8px;width:14px;"></i><%= item %></li>
                <% }) %>
              </ul>
            </div>
            <div class="list-item" style="padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <i class="fa-solid fa-triangle-exclamation" style="color:#fcd34d;font-size:16px;"></i>
                <strong><%= page.violationsTitle %></strong>
              </div>
              <div class="table-wrap">
                <table class="table">
                  <thead><tr><th><%= page.table.type %></th><th><%= page.table.description %></th><th><%= page.table.consequence %></th></tr></thead>
                  <tbody>
                    <% page.rows.forEach((row) => { %>
                      <tr><td><%= row.type %></td><td><%= row.description %></td><td><%= row.consequence %></td></tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="list-item" style="padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <i class="fa-solid fa-envelope" style="color:#a5b4fc;font-size:16px;"></i>
                <strong><%= page.reportTitle %></strong>
              </div>
              <p style="font-size:13px;color:rgba(255,255,255,.8);line-height:1.6;"><%= page.reportDescription %></p>
            </div>
          </div>
        </article>
      </section>
      <%- include('../partials/footer') %>
    </main>
  </div>
</body>
</html>
