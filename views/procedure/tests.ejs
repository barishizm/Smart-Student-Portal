<!DOCTYPE html>
<html lang="<%= currentLanguage %>">
<head>
  <%- include('../partials/head') %>
  <% const page = t('testsPage'); %>
  <title>VILNIUS TECH | <%= page.title %></title>
</head>
<body>
  <div class="dash">
    <%- include('../partials/sidebar') %>
    <main class="main">
      <%- include('../partials/header') %>
      <section class="content">
        <article class="card">
          <div class="card-head">
            <h2><%= page.title %></h2>
            <span class="badge"><%= page.badge %></span>
          </div>
          <p class="muted" style="margin-bottom:20px;"><%= page.description %></p>
          <div class="table-wrap" style="margin-bottom:20px;">
            <table class="table">
              <thead><tr><th><%= page.table.subject %></th><th><%= page.table.assessment %></th><th><%= page.table.weight %></th><th><%= page.table.deadline %></th><th><%= page.table.status %></th></tr></thead>
              <tbody>
                <% page.rows.forEach((row) => { %>
                  <tr><td><%= row.subject %></td><td><%= row.assessment %></td><td><%= row.weight %></td><td><%= row.deadline %></td><td><span class="badge" style="background:<%= row.statusBackground %>;color:<%= row.statusColor %>;border-color:<%= row.statusBorder %>;"><%= row.status %></span></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="list-item" style="padding:14px 16px;">
            <p style="font-size:13px;color:rgba(255,255,255,.8);line-height:1.6;"><i class="fa-solid fa-circle-info" style="color:#67e8f9;margin-right:8px;"></i><%= page.note %></p>
          </div>
        </article>
      </section>
      <%- include('../partials/footer') %>
    </main>
  </div>
</body>
</html>
